# pyenv
#   For a library or binary, you shouldn't ignore this file.
#   For an application, you should.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, in case of collaboration, if having platform-specific dependencies or dependencies
#   having no cross-platform support, pipenv may install dependencies that don't work, or even
#   fail to install. In that case, the lock file should be added to .gitignore.
#Pipfile.lock

# poetry
#   Similar to Pipenv, see above.
#poetry.lock

# pdm
#   Similar to Pipenv, see above.
#pdm.lock
.pdm-python
.pdm-build/

# PEP 582; used by e.g. github.com/fannheyward/coc-pyright
